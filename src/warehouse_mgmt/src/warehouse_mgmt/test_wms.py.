import pandas as pd
import numpy as np
import os
from src.warehouse_mgmt.slotting_optimizer import SlottingOptimizer

def run_wms_test():
    if not os.path.exists('data'):
        os.makedirs('data')
    
    # 1. Génération de données de stock simulées (100 SKUs)
    np.random.seed(42)
    skus = [f'SKU_{i:03d}' for i in range(1, 101)]
    # Loi de Pareto : quelques produits sortent beaucoup, la plupart très peu
    quantities = np.random.exponential(scale=100, size=100).astype(int)
    
    df_inventory = pd.DataFrame({'sku_id': skus, 'quantity_out': quantities})
    df_inventory.to_csv('data/inventory_movements.csv', index=False)
    
    # 2. Exécution de l'optimiseur
    optimizer = SlottingOptimizer()
    optimizer.load_inventory_data('data/inventory_movements.csv')
    abc_results = optimizer.calculate_abc_segmentation()
    
    # 3. Affichage des résultats stratégiques
    print("--- Analyse ABC Terminée ---")
    print(abc_results['abc_class'].value_counts())
    
    a_items = optimizer.suggest_relocation(abc_results)
    print(f"\nTop 3 SKUs à placer en zone de préparation rapide (Zone A) :")
    for item in a_items[:3]:
        print(f"- {item['sku_id']}")

if __name__ == "__main__":
    run_wms_test()
